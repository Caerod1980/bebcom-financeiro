# ===========================================
# BEBCOM FINANCEIRO - VARIÁVEIS DE AMBIENTE
# ===========================================

# BACKEND CONFIGURATION
PORT=5000
NODE_ENV=development
JWT_SECRET=bebcom_secret_key_change_this_in_production_2026
JWT_EXPIRE=7d

# MONGODB ATLAS CONNECTION
# Substitua pelos seus dados do MongoDB Atlas
MONGODB_URI=mongodb+srv://seu_usuario:sua_senha@seu_cluster.mongodb.net/bebcom_financeiro

# FRONTEND URL (para CORS)
FRONTEND_URL=http://localhost:3000

# EMAIL CONFIG (opcional - para recuperação de senha futuro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app

# BACKUP CONFIG (opcional)
BACKUP_ENABLED=false
BACKUP_PATH=./backups
